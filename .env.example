## Google Places / Geocoding API key. Used for real restaurant search, details, photos, and address geocoding.
## Get one at https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_PLACES_API_KEY=

## Supabase project credentials. Used for auth, database, and realtime group rooms.
## Get these from your Supabase project settings > API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

## AI provider key (OpenAI or Gemini). Used for natural-language recommendations and group summaries.
## If left blank, the app falls back to a local rule-based recommendation engine.
VITE_AI_API_KEY=
VITE_AI_PROVIDER=openai
